{
  "name": "sherpa",
  "version": "2026.3.13",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names mcp,studio --prefix-colors blue,green \"pnpm mcp\" \"pnpm --filter @sherpa/studio-app dev\"",
    "dev:studio": "pnpm --filter @sherpa/studio-app dev",
    "mcp": "pnpm dlx tsx packages/studio-mcp/src/main.ts",
    "dev:web": "pnpm --filter @sherpa/website dev",
    "build": "pnpm --filter @sherpa/studio-app build",
    "build:web": "pnpm --filter @sherpa/website build",
    "check": "pnpm -r check",
    "storybook": "pnpm --filter @sherpa/storybook dev",
    "build:storybook": "pnpm --filter @sherpa/storybook build && mkdir -p apps/website/public/storybook && cp -r apps/storybook/storybook-static/* apps/website/public/storybook/",
    "build:all": "pnpm build:storybook && pnpm build",
    "build:all:web": "pnpm build:storybook && pnpm build:web",
    "sync:db": "pnpm dlx tsx scripts/sync-knowledge-db.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "ai": "^6.0.116"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
