{
  "name": "sherpa",
  "version": "2026.3.13",
  "private": true,
  "type": "module",
  "description": "Behavioral agentic collaboration framework — filesystem-based governance, behavioral agent definitions, and a Planner/Worker/Judge dispatch pipeline for Human+AI development workflows.",
  "keywords": [
    "ai-agents",
    "agentic-workflows",
    "governance",
    "human-in-the-loop",
    "mcp",
    "developer-tools",
    "monorepo"
  ],
  "homepage": "https://sherpa.solar",
  "bugs": "https://github.com/robabby/sherpa/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robabby/sherpa.git"
  },
  "license": "MIT",
  "author": "Sherpa Consulting (https://sherpa.solar)",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "concurrently --names mcp,studio --prefix-colors blue,green \"pnpm mcp\" \"pnpm --filter @sherpa/studio-app dev\"",
    "dev:studio": "pnpm --filter @sherpa/studio-app dev",
    "mcp": "pnpm dlx tsx packages/studio-mcp/src/main.ts",
    "dev:web": "pnpm --filter @sherpa/website dev",
    "build": "pnpm --filter @sherpa/studio-app build",
    "build:web": "pnpm --filter @sherpa/website build",
    "check": "pnpm -r check",
    "sync:db": "pnpm dlx tsx scripts/sync-knowledge-db.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "ai": "^6.0.116"
  }
}
