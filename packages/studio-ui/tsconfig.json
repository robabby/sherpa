{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@/*": ["../../apps/studio/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
